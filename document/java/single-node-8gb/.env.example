# ===== Single-node 8GB profile =====
# Copy to .env and update values before start.

TZ=Asia/Shanghai

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=quantiadb
MYSQL_USER=quantia
MYSQL_PASSWORD=change_me_app
MYSQL_PORT=3306

# RabbitMQ
RABBITMQ_USER=quantia
RABBITMQ_PASSWORD=change_me_rmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Java services
NOTIFICATION_IMAGE=ghcr.io/your-org/notification-svc:latest
IM_GATEWAY_IMAGE=ghcr.io/your-org/im-gateway-svc:latest
NOTIFICATION_PORT=8081
IM_GATEWAY_PORT=8082

# JVM limits for 8GB machine
JAVA_XMS=256m
JAVA_XMX=768m

# Optional observability profile
PROMETHEUS_PORT=9090
NODE_EXPORTER_PORT=9100

# Log retention helper
LOG_RETENTION_DAYS=7
