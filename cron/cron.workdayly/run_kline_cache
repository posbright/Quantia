#!/bin/bash
# K线缓存增量更新 — 批量更新 ~5000 只股票的历史K线缓存
# 前置条件：run_fetch 当日已成功完成（通过 cn_job_status 检查）
# 内存密集型任务，独立运行避免 OOM 影响其他任务
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PROJECT_ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)
source "$PROJECT_ROOT/cron/_common.sh"

init_env
LOG_FILE=$LOG_DIR/workdayly.log

check_trade_day "K线缓存更新"

# ── OOM 防护：停止非关键服务，释放内存 ──
# 拆分模式下本脚本独立调度（23:00），需自行停服；run_workdayly 编排模式
# 已统一管理服务生命周期，会设 QUANTIA_NO_SERVICE_STOP=1 抑制此处重复停服。
SERVICES_STOPPED=0

# 信号安全：确保异常退出（SIGTERM/SIGINT/OOM kill）时也恢复服务
_cleanup_services() {
    if [ $SERVICES_STOPPED -eq 1 ]; then
        SERVICES_STOPPED=0
        start_services_after_memory
    fi
}
trap _cleanup_services EXIT

if [ "${QUANTIA_NO_SERVICE_STOP:-0}" != "1" ]; then
    stop_services_for_memory "K线缓存增量更新（内存密集型）"
    SERVICES_STOPPED=1
fi

# 默认超时放宽到 6h：已消除重复删缓存主因后，首次除权重建/源站退化/补量运行
# 仍可能超过 2h；超时在这里是防卡死安全网，不应截断正常慢任务。
run_job "K线缓存增量更新 (kline_cache_daily_job)" "quantia/job/kline_cache_daily_job.py" "${QUANTIA_KLINE_TIMEOUT:-21600}"

# EXIT trap 会自动恢复服务
