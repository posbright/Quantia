#!/bin/bash
# Phase 4: 定时 AI 报告分析 + 评分预警推送
# 每日工作日收盘后调度（在模拟交易之后执行）
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PROJECT_ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)
source "$PROJECT_ROOT/cron/_common.sh"

init_env
LOG_FILE=$LOG_DIR/report_alert.log

# T+1 凌晨运行：按「最近交易日」判定，确保周六凌晨可处理周五数据
check_trade_day_t1 "AI报告+评分预警"

log_info "开始 AI 定时分析 + 评分预警..."
cd "$PROJECT_ROOT"
# 超时兜底放宽到 2h：每只股票 run_agent 最多 4 轮 × 60s LLM + 工具调用，理论上限
# ~8min/只 × max-stocks 10 ≈ 80min，故 1h 偏紧、有截断正常运行的风险；2h 留足余量。
# 本阶段在 Phase 2/3 服务已恢复后运行，后续仅 6/7（综合指标池/AI知识库，秒级），放宽无副作用。
timeout "${QUANTIA_REPORT_TIMEOUT:-7200}" "$PYTHON_BIN" -m quantia.job.stock_report_scheduled --mode all --max-stocks 10 >> "$LOG_FILE" 2>&1
EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
    log_info "AI 定时分析 + 评分预警完成 ✓"
elif [ $EXIT_CODE -eq 124 ]; then
    log_warn "AI 定时分析 + 评分预警超时 ✗ (限制 ${QUANTIA_REPORT_TIMEOUT:-7200}s)"
else
    log_warn "AI 定时分析 + 评分预警异常 (exit=$EXIT_CODE)"
fi

# 退出码透传给编排器（run_workdayly 的 Phase 5 失败计数）
exit $EXIT_CODE
