#!/bin/bash
# Phase 4: 定时 AI 报告分析 + 评分预警推送
# 每日工作日收盘后调度（在模拟交易之后执行）
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PROJECT_ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)
source "$PROJECT_ROOT/cron/_common.sh"

init_env
LOG_FILE=$LOG_DIR/report_alert.log

check_trade_day "AI报告+评分预警"

log_info "开始 AI 定时分析 + 评分预警..."
cd "$PROJECT_ROOT"
"$PYTHON_BIN" -m quantia.job.stock_report_scheduled --mode all --max-stocks 10 >> "$LOG_FILE" 2>&1
EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
    log_info "AI 定时分析 + 评分预警完成 ✓"
else
    log_warn "AI 定时分析 + 评分预警异常 (exit=$EXIT_CODE)"
fi
