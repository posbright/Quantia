#!/bin/bash
# 完整每日任务 — 串行执行 fetch → kline_cache → analysis
# 等价于分别调度三个独立脚本，但适合单机一键执行
# 每个阶段失败不影响后续阶段继续执行
#
# OOM 防护：Phase 2/3 是内存密集型任务，执行前自动停止
# nginx + Quantia Web 服务，完成后自动恢复。
# 可通过 QUANTIA_STOP_SERVICES 配置需要停止的服务。
# 设置 QUANTIA_NO_SERVICE_STOP=1 可禁用此行为。
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PROJECT_ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)
source "$PROJECT_ROOT/cron/_common.sh"

init_env
LOG_FILE=$LOG_DIR/workdayly.log

check_trade_day "每日任务"

OVERALL_START=$(date +%s)
FAILED=0
log_info "============ 每日完整任务开始 ============"

# Phase 1: 数据获取（API 调用，内存占用低，无需停服务）
# 抑制 run_fetch 自带的服务停止（由本脚本统一管理服务生命周期）
QUANTIA_NO_SERVICE_STOP=1 run_sub "Phase 1: 数据获取" "$SCRIPT_DIR/run_fetch" || FAILED=$((FAILED + 1))

# ── OOM 防护：停止非关键服务，释放内存 ──
SERVICES_STOPPED=0

# 信号安全：确保异常退出时也恢复服务
_cleanup_services() {
    if [ $SERVICES_STOPPED -eq 1 ]; then
        SERVICES_STOPPED=0
        start_services_after_memory
    fi
}
trap _cleanup_services EXIT

if [ "${QUANTIA_NO_SERVICE_STOP:-0}" != "1" ]; then
    stop_services_for_memory "Phase 2/3 内存密集型任务"
    SERVICES_STOPPED=1
fi

# Phase 2: K线缓存增量更新（内存密集型）
run_sub "Phase 2: K线缓存更新" "$SCRIPT_DIR/run_kline_cache" || FAILED=$((FAILED + 1))

# Phase 3: 数据分析（零 API，纯本地计算）
run_sub "Phase 3: 数据分析" "$SCRIPT_DIR/run_analysis" || FAILED=$((FAILED + 1))

# 主动恢复服务（trap 也会兜底）
if [ $SERVICES_STOPPED -eq 1 ]; then
    SERVICES_STOPPED=0
    start_services_after_memory
fi

# Phase 4: 模拟交易（依赖数据获取+K线缓存，内存占用低）
run_sub "Phase 4: 模拟交易" "$SCRIPT_DIR/run_paper_trading" || FAILED=$((FAILED + 1))

OVERALL_END=$(date +%s)
OVERALL_DUR=$((OVERALL_END - OVERALL_START))
OVERALL_STR=$(elapsed_fmt $OVERALL_DUR)

if [ $FAILED -eq 0 ]; then
    log_info "============ 每日完整任务结束 ✓ (全部成功, ${OVERALL_STR}) ============"
else
    log_warn "============ 每日完整任务结束 ✗ (${FAILED}/4 阶段异常, ${OVERALL_STR}) ============"
fi
