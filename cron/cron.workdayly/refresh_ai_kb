#!/bin/bash
# M9 — 工作日刷新 AI 知识库（template / doc / strategy / backtest_failure）
# 写入 cn_stock_ai_kb（FULLTEXT 索引）
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PROJECT_ROOT=$(cd "$SCRIPT_DIR/../.." && pwd)
source "$PROJECT_ROOT/cron/_common.sh"

init_env
LOG_FILE=$LOG_DIR/refresh_ai_kb.log

# 知识库索引器不区分交易日，每个工作日跑一次即可。
cd "$PROJECT_ROOT"
echo "[$(date +'%F %T')] 开始刷新 AI 知识库..." | tee -a "$LOG_FILE"
"$PYTHON_BIN" -m quantia.lib.ai.retrieval.indexer >>"$LOG_FILE" 2>&1
RC=$?
echo "[$(date +'%F %T')] 完成 (rc=$RC)" | tee -a "$LOG_FILE"
exit $RC
