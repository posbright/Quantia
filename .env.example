# ============================================================
# Quantia 环境变量配置
# ============================================================
# 复制本文件为 .env 并根据需要修改。
# 优先级：系统环境变量 > .env 文件 > 旧兼容变量 > 代码默认值
# 未设置的变量将使用注释中标注的默认值。
# 配置统一使用 QUANTIA_*。
# ============================================================

# ============ 数据库连接（必填） ============
QUANTIA_DB_HOST=127.0.0.1
QUANTIA_DB_USER=root
QUANTIA_DB_PASSWORD=your_password_here
QUANTIA_DB_DATABASE=quantiadb
QUANTIA_DB_PORT=3306
# QUANTIA_DB_CHARSET=utf8mb4

# ============ 数据库连接池 ============
# QUANTIA_DB_CONNECT_TIMEOUT=10      # 连接超时（秒）
# QUANTIA_DB_READ_TIMEOUT=30         # 读取超时（秒）
# QUANTIA_DB_WRITE_TIMEOUT=30        # 写入超时（秒）
# QUANTIA_DB_POOL_SIZE=2             # 连接池基础大小
# QUANTIA_DB_MAX_OVERFLOW=3          # 连接池最大溢出数
# QUANTIA_DB_POOL_RECYCLE=600        # 连接回收周期（秒）
# QUANTIA_DB_POOL_TIMEOUT=30         # 获取连接超时（秒）
# QUANTIA_DB_MAX_RETRIES=3           # 启动时数据库连接重试次数
# QUANTIA_DB_RETRY_DELAY=5           # 重试间隔（秒）

# ============ 数据源 ============
# DATA_SOURCE_MAX_RETRIES=2          # 单数据源最大重试次数
# DATA_SOURCE_RETRY_INTERVAL=90      # 重试基础间隔（秒，指数退避）
# HIST_DATA_DEFAULT_YEARS=10         # 默认获取历史数据年数（1-20）
# DATA_SOURCE_FAIL_THRESHOLD=5       # 连续失败多少次后降级该数据源
# DATA_SOURCE_COOLDOWN_SECONDS=300   # 数据源降级冷却时间（秒）
# DATA_SOURCE_MAX_COOLDOWN=3600      # 数据源最大冷却时间（秒）

# ============ 东方财富 ============
# EAST_MONEY_COOKIE=                 # 东方财富 Cookie（覆盖文件和默认值）
# QUANTIA_EM_RETRY=3                 # 东方财富 API 请求重试次数
# QUANTIA_EM_TIMEOUT=30              # 东方财富 API 请求超时（秒）

# ============ 代理池 ============
# QUANTIA_PROXY_VALIDATE_URL=http://datacenter.eastmoney.com/api/data/get
# QUANTIA_PROXY_VALIDATE_TIMEOUT=5   # 代理验证超时（秒）
# QUANTIA_PROXY_REFRESH_INTERVAL=600 # 代理池后台刷新间隔（秒）
# QUANTIA_PROXY_MIN_POOL_SIZE=3      # 代理池最小数量
# QUANTIA_PROXY_FETCH_WORKERS=50     # 代理验证并发线程数
# QUANTIA_PROXY_INIT_BATCH_SIZE=200  # 初始化时验证的候选代理数
# QUANTIA_PROXY_MAX_FAIL_COUNT=3     # 连续失败次数阈值，超过则移除
# QUANTIA_PROXY_STALE_SECONDS=600    # 代理验证结果过期时间（秒）
# QUANTIA_PROXY_CACHE_MAX_AGE=86400  # 代理磁盘缓存 TTL（秒）
# QUANTIA_PROXY_TARGET_POOL_SIZE=15  # 代理池目标数量
# QUANTIA_PROXY_EMERGENCY_COOLDOWN=30 # 紧急补充代理冷却时间（秒）

# ============ 作业控制 ============
# QUANTIA_FORCE_FETCH=0              # 强制获取数据（跳过新鲜度检查）
# QUANTIA_FORCE_ANALYSIS=0           # 强制执行分析（即使已完成）
# QUANTIA_FORCE_KLINE_CACHE=0        # 强制K线缓存更新（跳过依赖检查）
# QUANTIA_ANALYSIS_DONE_THRESHOLD=1000 # 分析完成判定：指标表行数阈值

# ============ 数据新鲜度阈值 ============
# QUANTIA_FRESH_STOCK_SPOT=3000      # cn_stock_spot 最低行数
# QUANTIA_FRESH_ETF_SPOT=200         # cn_etf_spot 最低行数
# QUANTIA_FRESH_SELECTION=100        # cn_stock_selection 最低行数
# QUANTIA_FRESH_FUND_FLOW=2000       # cn_stock_fund_flow 最低行数

# ============ 并发控制 ============
# QUANTIA_BATCH_SIZE=50              # 流式分析每批股票数
# QUANTIA_ANALYSIS_WORKERS=2         # 流式分析并发线程数
# QUANTIA_INDICATOR_WORKERS=4        # 指标计算并发线程数
# QUANTIA_KLINE_PATTERN_WORKERS=4    # K线形态识别并发线程数
# QUANTIA_STRATEGY_WORKERS=4         # 策略计算并发线程数（内层，按股票）
# QUANTIA_STRATEGY_OUTER_WORKERS=2   # 策略外层并发数（按策略表）
# QUANTIA_KLINE_CACHE_WORKERS=2      # K线缓存更新并发数
# QUANTIA_BACKTEST_OUTER_WORKERS=1   # 回测外层并发（按表）
# QUANTIA_BACKTEST_INNER_WORKERS=2   # 回测内层并发（按股票）
# QUANTIA_BATCH_DATE_WORKERS=3       # 批量日期作业并发数
# QUANTIA_CRAWL_WORKERS=5            # 数据爬取并发线程数（新浪/腾讯）
# QUANTIA_DB_CONN_RETRIES=3          # 数据库操作重试次数（get_connection/insert/executeSql）

# ============ 本地/服务器环境模式 ============
# QUANTIA_LOCAL_MODE=1               # 本地模式（高并发、少延迟、大内存）
#   本地模式默认值：6线程、请求间隔0.3-0.8秒、每200只暂停3-6秒
#   服务器模式默认值：2线程、请求间隔1.0-3.0秒、每100只暂停8-15秒

# ============ K线缓存限流控制 ============
# QUANTIA_KLINE_REQUEST_DELAY_MIN=1.0    # K线请求最小间隔（秒）
# QUANTIA_KLINE_REQUEST_DELAY_MAX=3.0    # K线请求最大间隔（秒）
# QUANTIA_KLINE_BATCH_INTERVAL=100       # 每N只股票暂停一次
# QUANTIA_KLINE_BATCH_PAUSE_MIN=8        # 批次暂停最小秒数
# QUANTIA_KLINE_BATCH_PAUSE_MAX=15       # 批次暂停最大秒数
# QUANTIA_KLINE_CHUNK_SIZE=100           # 分批处理大小

# ============ 子进程超时 ============
# QUANTIA_JOB_TIMEOUT=1800           # 子进程默认超时（秒，默认 30 分钟）
# QUANTIA_KLINE_JOB_TIMEOUT=36000    # K线缓存子进程超时（秒，默认 10 小时）

# ============ 数据结算 ============
# QUANTIA_SETTLEMENT_HOUR=18         # API 数据结算时间（小时，默认 18）
                                     # A股收盘 15:00，但龙虎榜/大宗交易等数据延迟发布
                                     # 在此时间之前每次执行都会重新获取 API 数据
                                     # 在此时间之后若数据行数达标则跳过重复获取

# ============ 查询缓存 ============
# QUANTIA_CACHE_MAX_SIZE=512         # 股票数据查询缓存最大条目
# QUANTIA_CACHE_TTL=300              # 查询缓存 TTL（秒）
# QUANTIA_FILTER_CACHE_MAX_SIZE=128  # 策略筛选缓存最大条目
# QUANTIA_FILTER_CACHE_TTL=600       # 筛选缓存 TTL（秒）

# ============ Web 服务 ============
# QUANTIA_WEB_PORT=9988              # Tornado 监听端口

# ============ 日志 ============
# QUANTIA_LOG_MAX_BYTES=10485760     # 单个日志文件最大大小（字节，默认 10MB）
# QUANTIA_LOG_BACKUP_COUNT=5         # 日志轮转保留文件数

# ============ 交易 / 回测 ============
# QUANTIA_TURTLE_BALANCE=200000      # 海龟策略模拟资金
# QUANTIA_COMMISSION_RATE=0.00025    # 佣金率（单边，0.025%）
# QUANTIA_STAMP_TAX_RATE=0.0005     # 印花税（卖方，0.05%）
# QUANTIA_SLIPPAGE_RATE=0.0005      # 滑点率（单边，0.05%）

# ============ OOM 防护（低内存服务器） ============
# QUANTIA_STOP_SERVICES=nginx        # 内存密集型任务前停止的系统服务（空格分隔）
# QUANTIA_NO_SERVICE_STOP=0          # 设为 1 禁用自动停止/恢复服务

# ============================================================
# Phase 8 鉴权 / RBAC（默认全部关闭，开启需显式设置）
# ============================================================
# 启用后才会校验 cookie/CSRF；未启用时所有 API 直通，前端 /api/auth/me
# 返回 { enabled:false }，用户管理与注册页仍可访问但写入受限。

# QUANTIA_AUTH_ENABLED=false         # 总开关；true/1/yes 启用，其余关闭
# QUANTIA_SESSION_TTL_HOURS=12       # 登录会话/secure_cookie TTL（小时）
                                     # 取值范围 1-168（1 小时-7 天），无效值回退默认

# ── 内嵌 admin 单账户（可选，DB 故障时仍可登录） ──
# QUANTIA_ADMIN_USER=admin           # 默认 admin
# QUANTIA_ADMIN_PASS_BCRYPT=         # bcrypt 哈希；为空则禁用 env 单账户
#   生成方式（任选其一）：
#     python -c "import bcrypt; print(bcrypt.hashpw(b'your-pass', bcrypt.gensalt()).decode())"
#     htpasswd -nbB admin 'your-pass'

# ── 钉钉 IM 回调 IP 白名单（与登录解耦的独立保护） ──
# QUANTIA_DINGTALK_CALLBACK_ALLOW_IPS=  # 逗号分隔，支持 IP 或 CIDR
#   示例：106.11.0.0/16,140.205.0.0/16
#   留空 = 不校验来源 IP（仅签名校验）

# ============================================================
# 自助注册 / 邮箱验证码（Phase 8 扩展）
# ============================================================
# 用户可通过「邮箱 + 6 位数字验证码 + 密码 + 昵称」自助注册，
# 注册成功默认获得 viewer 角色（只读），admin 可在用户管理页提权。
# 登录支持「用户名 / 邮箱 / 昵称」三选一。

# QUANTIA_REGISTER_ENABLED=true      # 自助注册总开关；设为 false 关闭注册端点
# QUANTIA_REGISTER_DEV_MODE=false    # 开发模式：API 响应额外回显 dev_code，
                                     # 便于本地无 SMTP 时联调；生产务必关闭

# ── SMTP 邮件发送（生产环境必填，否则发码会失败） ──
# QUANTIA_SMTP_HOST=smtp.exmail.qq.com  # SMTP 服务器地址
# QUANTIA_SMTP_PORT=465              # 端口；465=SMTPS（默认），587=STARTTLS
# QUANTIA_SMTP_USER=noreply@yourdomain.com   # 登录账号
# QUANTIA_SMTP_PASS=your_smtp_password_or_app_token  # 登录密码 / 应用专用密码
# QUANTIA_SMTP_FROM=noreply@yourdomain.com   # 发件人；留空则使用 SMTP_USER
# QUANTIA_SMTP_USE_SSL=true          # true=SMTP_SSL（465）；false=SMTP+STARTTLS（587）

# ── 验证码内置策略（代码常量，仅供参考，无 env 覆盖） ──
#   - 6 位数字，5 分钟有效
#   - 同一邮箱 60 秒内只允许重发一次
#   - 同一邮箱每日最多发送 10 次

# ── Tornado secure_cookie 加密密钥（生产必填） ──
# QUANTIA_SESSION_SECRET=                # 未设置时回退历史硬编码值，仅适合本地

# ============================================================
# AI 助手 / 多 Provider LLM（quantia/lib/ai, quantia/ai_decision）
# ============================================================
# 未配置 AI Provider 时，AI 决策、策略生成、对话等模块自动降级或返回 503。

# ── 默认 Provider（兼容旧命名 QUANTIA_AI_DEFAULT_*） ──
# QUANTIA_AI_PROVIDER=openai          # 默认 provider 名（与 PROVIDER_<NAME>_* 对齐）
# QUANTIA_AI_API_BASE=                # 默认 base URL，如 https://api.openai.com/v1
# QUANTIA_AI_API_KEY=                 # 默认 API Key（敏感，勿入库）
# QUANTIA_AI_MODEL=gpt-4o-mini        # 默认模型名
# QUANTIA_AI_TEMPERATURE=0.2          # 0-2 之间
# QUANTIA_AI_MAX_TOKENS=2048
# QUANTIA_AI_TIMEOUT=60               # 单次请求超时（秒）
# QUANTIA_AI_DEFAULT_PROVIDER=default # 启动时挑选哪个 profile 作为默认

# ── 命名 Provider Profile（可重复，用大写 NAME 区分） ──
# QUANTIA_AI_PROVIDER_OPENAI_API_BASE=https://api.openai.com/v1
# QUANTIA_AI_PROVIDER_OPENAI_API_KEY=
# QUANTIA_AI_PROVIDER_OPENAI_MODELS=gpt-4o-mini,gpt-4o
# QUANTIA_AI_PROVIDER_OPENAI_DEFAULT_MODEL=gpt-4o-mini
# QUANTIA_AI_PROVIDER_DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# QUANTIA_AI_PROVIDER_DEEPSEEK_API_KEY=
# QUANTIA_AI_PROVIDER_DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ── Agent / 记忆 / 审计 ──
# QUANTIA_AI_AGENT_MAX_ROUNDS=4          # 工具调用最大轮数
# QUANTIA_AI_MEMORY_BACKEND=db           # db|inmem
# QUANTIA_AI_MEMORY_MAX_CONVS=200        # inmem LRU 容量（10-5000）
# QUANTIA_AI_MEMORY_MAX_TOKENS=4000      # 单次注入历史的 token 上限
# QUANTIA_AI_AUDIT_MAX_BYTES=131072      # 审计 payload 单字段最大字节
# QUANTIA_AI_MAX_GENERATED_CHARS=262144  # 一次返回给前端的最大字符数

# ── 策略修复（auto-repair） ──
# QUANTIA_AI_REPAIR_RUN_PREFLIGHT=       # 1=每次修复前跑 preflight；空=测试自动跳过
# QUANTIA_AI_REPAIR_MAX_ATTEMPTS=3       # 最大修复尝试次数

# ── Web 搜索工具（可选；未配置则使用内置 DuckDuckGo 搜索） ──
# QUANTIA_AI_WEB_SEARCH_URL=             # 自建搜索代理 URL（SearXNG 等）；留空使用内置 DuckDuckGo
# QUANTIA_AI_WEB_SEARCH_KEY=
# QUANTIA_AI_WEB_SEARCH_ALLOW_HTTP=0     # 1 允许 http（内网调试用）

# ── 速率限制（默认开启，CI 可关） ──
# QUANTIA_AI_RATE_CALLS_PER_HOUR=120
# QUANTIA_AI_RATE_TOKENS_PER_HOUR=200000
# QUANTIA_AI_RATE_DISABLED=0             # 1 全局禁用 AI 限流

# ============================================================
# 通知 / 钉钉机器人（quantia/notification）
# ============================================================
# 通知模板的链接基址 + 默认机器人 webhook/secret。
# 自定义通道可在数据库 cn_notification_channel 表中按用户配置。

# QUANTIA_WEB_BASE_URL=http://your-host:9988
#                                       # 通知中的卡片跳转地址；末尾 /quantia 会被自动剥离
# QUANTIA_DINGTALK_WEBHOOK=             # 默认机器人 webhook URL
# QUANTIA_DINGTALK_SECRET=              # 加签 secret（钉钉机器人安全设置）
# QUANTIA_DINGTALK_CALLBACK_SECRET=     # 钉钉回调签名校验 secret
# QUANTIA_DINGTALK_CALLBACK_RPM=0       # 回调接口 RPM 限流；0 = 禁用

# ============================================================
# IM 指令通道（quantia/im，钉钉 ChatOps）
# ============================================================
# QUANTIA_IM_COMMAND_ENABLED=false       # 关闭时回调直接 503
# QUANTIA_IM_MAX_SINGLE_VALUE=100000     # 单笔指令最大金额（元）
# QUANTIA_IM_MAX_DAILY_VALUE=500000      # 单日累计金额上限（元）
# QUANTIA_IM_COMMAND_TTL_SECONDS=300     # 待确认指令的过期时间

# ============================================================
# Phase 7 实盘交易 / Phase 6 模拟盘
# ============================================================
# QUANTIA_LIVE_TRADING_ENABLED=false     # 主开关；关闭时拒绝 Phase 6 信号路由
# QUANTIA_LIVE_BROKER=dry_run            # broker 名（需提前 register_broker 注册）
# QUANTIA_TRADING_HOURS=09:30-11:30,13:00-15:00
#                                        # 留空 = 不限制时间窗（仅供 live executor 使用）
# QUANTIA_LIVE_EXECUTE_RPS=0             # /quantia/api/live/execute 限流 RPS；0 = 禁用
# QUANTIA_PAPER_DAILY_AFTER_HOUR=16      # 每日 paper trading 运行的最早小时（A 股收盘+落库后）

# ============================================================
# 验证中心 fallback 回测
# ============================================================
# 数据库历史不足时是否触发现算回测兜底（买卖点优化、策略对比等）。
# QUANTIA_VERIFY_FALLBACK_ENABLED=true
# QUANTIA_VERIFY_FALLBACK_MAX_STOCKS=300 # 单次 fallback 最多回测多少只股票
# QUANTIA_VERIFY_FALLBACK_WORKERS=4      # fallback 并发线程

# ============================================================
# 全量回测任务超时
# ============================================================
# QUANTIA_BACKTEST_TIMEOUT=7200          # analysis_daily_job 中回测子进程超时（秒）

# ============================================================
# 财报数据抓取（quantia/job/stock_financial_data.py）
# ============================================================
# QUANTIA_FINANCIAL_SLEEP=2.0            # 每只股票之间的间隔（秒）
# QUANTIA_FINANCIAL_RETRIES=2            # 单只重试次数
# QUANTIA_FINANCIAL_RETRY_SLEEP=5        # 重试间隔（秒）

# ============================================================
# 爬虫请求间隔（防限流；可全部关闭以加快本地调试）
# ============================================================
# QUANTIA_CRAWL_DELAY_ENABLED=true       # 0 = 完全关闭随机延迟
# QUANTIA_CRAWL_DELAY_EM_MIN=0.2         # 东方财富股票历史 K 线
# QUANTIA_CRAWL_DELAY_EM_MAX=0.5
# QUANTIA_CRAWL_DELAY_INDEX_MIN=0.2      # 东方财富指数 K 线
# QUANTIA_CRAWL_DELAY_INDEX_MAX=0.5
# QUANTIA_CRAWL_DELAY_TC_SHORT_MIN=0.3   # 腾讯短窗
# QUANTIA_CRAWL_DELAY_TC_SHORT_MAX=0.8
# QUANTIA_CRAWL_DELAY_TC_LONG_MIN=0.5    # 腾讯长窗
# QUANTIA_CRAWL_DELAY_TC_LONG_MAX=1.5
# QUANTIA_CRAWL_DELAY_SINA_MIN=3.0       # 新浪（最严，常 456）
# QUANTIA_CRAWL_DELAY_SINA_MAX=6.0

# ============================================================
# 内部 / 自动注入变量（不要手工写到 .env）
# ============================================================
# 以下变量由父进程在运行时设置，仅在子进程间传递阶段状态：
#   QUANTIA_PHASE2_FAILED   —— execute_daily_job 标记 Phase 2 失败，
#                              streaming_analysis_job 据此跳过分析阶段
