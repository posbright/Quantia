# ============================================================
# Quantia 量化选股系统 — 环境变量配置模板
# ============================================================
# 使用方法：复制本文件为 .env 并填写实际值
#   cp .env.example .env
# 优先级：系统环境变量 > .env 文件 > 代码默认值
# 标记 [必填] 的项目必须填写才能启动服务
# 标记 [推荐] 的项目有默认值但建议按环境调整
# 其余为可选项，注释状态即使用程序内置默认值
# ============================================================

# ============ 数据库连接（必填） ============
QUANTIA_DB_HOST=127.0.0.1                # [必填] MySQL 主机地址
QUANTIA_DB_USER=root                     # [必填] MySQL 用户名
QUANTIA_DB_PASSWORD=your_password_here   # [必填] MySQL 密码
QUANTIA_DB_DATABASE=instockdb            # [必填] 数据库名
QUANTIA_DB_PORT=3306                     # MySQL 端口
QUANTIA_DB_CHARSET=utf8mb4               # 字符集

# ============ 运行模式 ============
QUANTIA_LOCAL_MODE=1                     # [推荐] 1=本地模式（高并发、少延迟）；0=服务器保守模式

# ============ 通知 / 钉钉机器人 ============
# QUANTIA_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_access_token
# QUANTIA_DINGTALK_SECRET=your_dingtalk_secret
# QUANTIA_DINGTALK_CALLBACK_SECRET=     # 钉钉回调签名校验 secret
# QUANTIA_DINGTALK_CALLBACK_RPM=0       # 回调接口 RPM 限流；0=禁用

# ============ Web 服务 ============
QUANTIA_WEB_BASE_URL=http://127.0.0.1    # 外部可访问的 Web 基础 URL（用于分享链接等）
# QUANTIA_WEB_PORT=9988                  # Tornado 监听端口（默认 9988）

# ============ AI Provider 配置 ============
# 至少配置一个 provider 才能使用 AI 分析功能（决策/报告/策略生成）
# 未配置时 AI 功能自动降级或返回 503

QUANTIA_AI_DEFAULT_PROVIDER=qwen         # [推荐] 默认 provider: qwen / openai / deepseek / kimi / openrouter / local

# --- OpenAI ---
QUANTIA_AI_PROVIDER_OPENAI_API_BASE=https://api.openai.com/v1
QUANTIA_AI_PROVIDER_OPENAI_API_KEY=sk-your_openai_api_key
QUANTIA_AI_PROVIDER_OPENAI_MODELS=gpt-4,gpt-4o,gpt-4o-mini,gpt-3.5-turbo
QUANTIA_AI_PROVIDER_OPENAI_DEFAULT_MODEL=gpt-4o-mini

# --- DeepSeek ---
QUANTIA_AI_PROVIDER_DEEPSEEK_API_BASE=https://api.deepseek.com/v1
QUANTIA_AI_PROVIDER_DEEPSEEK_API_KEY=sk-your_deepseek_api_key
QUANTIA_AI_PROVIDER_DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# --- 通义千问 (Qwen) ---
QUANTIA_AI_PROVIDER_QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QUANTIA_AI_PROVIDER_QWEN_API_KEY=sk-your_qwen_api_key
QUANTIA_AI_PROVIDER_QWEN_DEFAULT_MODEL=qwen-plus
QUANTIA_AI_PROVIDER_QWEN_MODELS=qwen3.6-plus,qwen3.6,qwen3.5-plus,qwen3.7-max

# --- Kimi / Moonshot ---
# 注意：moonshot-v1-* 使用国内端点 api.moonshot.cn；kimi-k2-* 需要国际端点 api.moonshot.ai
QUANTIA_AI_PROVIDER_KIMI_API_BASE=https://api.moonshot.cn/v1
QUANTIA_AI_PROVIDER_KIMI_API_KEY=sk-your_kimi_api_key
QUANTIA_AI_PROVIDER_KIMI_DEFAULT_MODEL=moonshot-v1-8k
QUANTIA_AI_PROVIDER_KIMI_MODELS=moonshot-v1-8k,moonshot-v1-32k,moonshot-v1-128k
QUANTIA_AI_PROVIDER_KIMI_LABEL=Kimi (Moonshot)

# --- OpenRouter (多模型聚合) ---
QUANTIA_AI_PROVIDER_OPENROUTER_API_BASE=https://openrouter.ai/api/v1
QUANTIA_AI_PROVIDER_OPENROUTER_API_KEY=sk-or-your_openrouter_api_key
QUANTIA_AI_PROVIDER_OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-v4-pro
QUANTIA_AI_PROVIDER_OPENROUTER_MODELS=deepseek/deepseek-r1,deepseek/deepseek-v4-pro,moonshotai/kimi-k2,moonshotai/kimi-k2-thinking,baidu/ernie-4.5-300b-a47b,anthropic/claude-sonnet-4.6,anthropic/claude-opus-4.7,google/gemini-3.1-pro-preview,~openai/gpt-latest
QUANTIA_AI_PROVIDER_OPENROUTER_LABEL=OpenRouter

# --- 本地 Ollama（可选） ---
# QUANTIA_AI_PROVIDER_LOCAL_BASE_URL=http://localhost:11434/v1
# QUANTIA_AI_PROVIDER_LOCAL_API_KEY=ollama
# QUANTIA_AI_PROVIDER_LOCAL_DEFAULT_MODEL=qwen2.5:7b

# ── Agent / 记忆 / 审计 ──
# QUANTIA_AI_AGENT_MAX_ROUNDS=4          # 工具调用最大轮数
# QUANTIA_AI_MEMORY_BACKEND=db           # db|inmem
# QUANTIA_AI_MEMORY_MAX_CONVS=200        # inmem LRU 容量（10-5000）
# QUANTIA_AI_MEMORY_MAX_TOKENS=4000      # 单次注入历史的 token 上限
# QUANTIA_AI_AUDIT_MAX_BYTES=131072      # 审计 payload 单字段最大字节
# QUANTIA_AI_MAX_GENERATED_CHARS=262144  # 一次返回给前端的最大字符数

# ── 策略修复（auto-repair） ──
# QUANTIA_AI_REPAIR_RUN_PREFLIGHT=       # 1=每次修复前跑 preflight；空=测试自动跳过
# QUANTIA_AI_REPAIR_MAX_ATTEMPTS=3       # 最大修复尝试次数

# ── Web 搜索工具（可选；未配置则 web_search 工具返回不可用） ──
# QUANTIA_AI_WEB_SEARCH_URL=             # 必须 https；http 需放行
# QUANTIA_AI_WEB_SEARCH_KEY=your_web_search_key
# QUANTIA_AI_WEB_SEARCH_ALLOW_HTTP=0     # 1=允许 http（内网调试用）

# ── AI 速率限制 ──
# QUANTIA_AI_RATE_CALLS_PER_HOUR=120
# QUANTIA_AI_RATE_TOKENS_PER_HOUR=200000
# QUANTIA_AI_RATE_DISABLED=0             # 1=全局禁用 AI 限流

# ============ 数据库连接池 ============
# QUANTIA_DB_CONNECT_TIMEOUT=10      # 连接超时（秒）
# QUANTIA_DB_READ_TIMEOUT=30         # 读取超时（秒）
# QUANTIA_DB_WRITE_TIMEOUT=30        # 写入超时（秒）
# QUANTIA_DB_POOL_SIZE=2             # 连接池基础大小
# QUANTIA_DB_MAX_OVERFLOW=3          # 连接池最大溢出数
# QUANTIA_DB_POOL_RECYCLE=600        # 连接回收周期（秒）
# QUANTIA_DB_POOL_TIMEOUT=30         # 获取连接超时（秒）
# QUANTIA_DB_MAX_RETRIES=3           # 启动时数据库连接重试次数
# QUANTIA_DB_RETRY_DELAY=5           # 重试间隔（秒）

# ============ 数据源 ============
# DATA_SOURCE_MAX_RETRIES=2          # 单数据源最大重试次数
DATA_SOURCE_RETRY_INTERVAL=30        # 重试基础间隔（秒，指数退避）
# HIST_DATA_DEFAULT_YEARS=10         # 默认获取历史数据年数（1-20）
# DATA_SOURCE_FAIL_THRESHOLD=5       # 连续失败多少次后降级该数据源
# DATA_SOURCE_COOLDOWN_SECONDS=300   # 数据源降级冷却时间（秒）
# DATA_SOURCE_MAX_COOLDOWN=3600      # 数据源最大冷却时间（秒）

# ============ 爬虫内部延迟 ============
# 当调度层(update_all_caches)已有限流时，关闭爬虫内部延迟可消除双重等待
# 效果：每股节省 0.2-0.5s（东方财富）、0.3-1.5s（腾讯）、3-6s（新浪）
QUANTIA_CRAWL_DELAY_ENABLED=0        # 0=关闭爬虫内部延迟（本地推荐）；1=启用（服务器推荐）
# QUANTIA_CRAWL_DELAY_EM_MIN=0.2     # 东方财富K线API内部延迟下限（秒）
# QUANTIA_CRAWL_DELAY_EM_MAX=0.5     # 东方财富K线API内部延迟上限（秒）
# QUANTIA_CRAWL_DELAY_TC_SHORT_MIN=0.3  # 腾讯短请求延迟下限
# QUANTIA_CRAWL_DELAY_TC_SHORT_MAX=0.8  # 腾讯短请求延迟上限
# QUANTIA_CRAWL_DELAY_TC_LONG_MIN=0.5   # 腾讯长请求延迟下限
# QUANTIA_CRAWL_DELAY_TC_LONG_MAX=1.5   # 腾讯长请求延迟上限
# QUANTIA_CRAWL_DELAY_SINA_MIN=3.0   # 新浪K线API内部延迟下限（秒）
# QUANTIA_CRAWL_DELAY_SINA_MAX=6.0   # 新浪K线API内部延迟上限（秒）

# ============ Spot 快速追加（核心优化） ============
# 使用批量行情数据直接追加到K线缓存，替代逐股API调用
# 增量更新可从 ~5000次 降至 <100次 API调用
QUANTIA_SPOT_APPEND_ENABLED=1        # 1=启用Spot快速追加（推荐）
QUANTIA_SKIP_SUSPENDED=1             # 1=跳过停牌股（当日无K线数据）
QUANTIA_EXRIGHTS_THRESHOLD=0.01      # 除权除息检测阈值（1%=0.01，越小越敏感）

# ============ 东方财富 ============
# EAST_MONEY_COOKIE=                 # 东方财富 Cookie（覆盖文件和默认值）
# QUANTIA_EM_RETRY=3                 # 东方财富 API 请求重试次数
# QUANTIA_EM_TIMEOUT=30              # 东方财富 API 请求超时（秒）

# ============ 代理池 ============
# QUANTIA_PROXY_VALIDATE_URL=http://datacenter.eastmoney.com/api/data/get
# QUANTIA_PROXY_VALIDATE_TIMEOUT=5   # 代理验证超时（秒）
# QUANTIA_PROXY_REFRESH_INTERVAL=600 # 代理池后台刷新间隔（秒）
# QUANTIA_PROXY_MIN_POOL_SIZE=3      # 代理池最小数量
# QUANTIA_PROXY_FETCH_WORKERS=50     # 代理验证并发线程数
# QUANTIA_PROXY_INIT_BATCH_SIZE=200  # 初始化时验证的候选代理数
# QUANTIA_PROXY_MAX_FAIL_COUNT=3     # 连续失败次数阈值，超过则移除
# QUANTIA_PROXY_STALE_SECONDS=600    # 代理验证结果过期时间（秒）
# QUANTIA_PROXY_CACHE_MAX_AGE=86400  # 代理磁盘缓存 TTL（秒）
# QUANTIA_PROXY_TARGET_POOL_SIZE=15  # 代理池目标数量
# QUANTIA_PROXY_EMERGENCY_COOLDOWN=30 # 紧急补充代理冷却时间（秒）

# ============ 作业控制 ============
QUANTIA_FORCE_FETCH=1                # 1=强制获取数据（跳过新鲜度检查）
# QUANTIA_FORCE_ANALYSIS=0           # 1=强制执行分析（即使已完成）
QUANTIA_FORCE_KLINE_CACHE=1          # 1=强制K线缓存更新（跳过依赖检查）
# QUANTIA_ANALYSIS_DONE_THRESHOLD=1000 # 分析完成判定：指标表行数阈值

# ============ 数据新鲜度阈值 ============
# QUANTIA_FRESH_STOCK_SPOT=3000      # cn_stock_spot 最低行数
# QUANTIA_FRESH_ETF_SPOT=200         # cn_etf_spot 最低行数
# QUANTIA_FRESH_SELECTION=100        # cn_stock_selection 最低行数
# QUANTIA_FRESH_FUND_FLOW=2000       # cn_stock_fund_flow 最低行数

# ============ 并发控制 ============
QUANTIA_BATCH_SIZE=2000              # 流式分析每批股票数
QUANTIA_ANALYSIS_WORKERS=4           # 流式分析并发线程数
QUANTIA_INDICATOR_WORKERS=8          # 指标计算并发线程数
QUANTIA_KLINE_PATTERN_WORKERS=8      # K线形态识别并发线程数
QUANTIA_STRATEGY_WORKERS=8           # 策略计算并发线程数（内层，按股票）
# QUANTIA_STRATEGY_OUTER_WORKERS=2   # 策略外层并发数（按策略表）
QUANTIA_KLINE_CACHE_WORKERS=6        # K线缓存更新并发数（本地推荐6-8）
QUANTIA_BACKTEST_OUTER_WORKERS=2     # 回测外层并发（按表）
QUANTIA_BACKTEST_INNER_WORKERS=4     # 回测内层并发（按股票）
# QUANTIA_BATCH_DATE_WORKERS=3       # 批量日期作业并发数
# QUANTIA_CRAWL_WORKERS=5            # 数据爬取并发线程数（新浪/腾讯）
# QUANTIA_DB_CONN_RETRIES=3          # 数据库操作重试次数

# ============ K线缓存调度层延迟 ============
# 调度层(update_all_caches)自身的限流参数，与爬虫内部延迟独立
QUANTIA_KLINE_REQUEST_DELAY_MIN=0.1  # 每次API请求后等待下限（秒）
QUANTIA_KLINE_REQUEST_DELAY_MAX=0.3  # 每次API请求后等待上限（秒）
QUANTIA_KLINE_BATCH_PAUSE_MIN=1      # 批次暂停下限（秒）
QUANTIA_KLINE_BATCH_PAUSE_MAX=3      # 批次暂停上限（秒）
QUANTIA_KLINE_CHUNK_SIZE=500         # 每批提交的股票数

# ============ 指数K线缓存延迟 ============
# QUANTIA_INDEX_DELAY_MIN=0.5         # 指数间延迟下限（秒，默认 0.5）
# QUANTIA_INDEX_DELAY_MAX=1.5         # 指数间延迟上限（秒，默认 1.5）
# QUANTIA_CRAWL_DELAY_INDEX_MIN=0.2   # 指数K线API延迟下限（秒，默认 0.2）
# QUANTIA_CRAWL_DELAY_INDEX_MAX=0.5   # 指数K线API延迟上限（秒，默认 0.5）

# ============ 子进程超时 ============
# QUANTIA_JOB_TIMEOUT=1800           # 子进程默认超时（秒，默认 30 分钟）
# QUANTIA_KLINE_JOB_TIMEOUT=36000    # K线缓存子进程超时（秒，默认 10 小时）

# ============ 数据结算 ============
# QUANTIA_SETTLEMENT_HOUR=18         # API 数据结算时间（小时，默认 18）
                                     # A股收盘 15:00，但龙虎榜/大宗交易等数据延迟发布
                                     # 在此时间之前每次执行都会重新获取 API 数据
                                     # 在此时间之后若数据行数达标则跳过重复获取

# ============ 查询缓存 ============
# QUANTIA_CACHE_MAX_SIZE=512         # 股票数据查询缓存最大条目
# QUANTIA_CACHE_TTL=300              # 查询缓存 TTL（秒）
# QUANTIA_FILTER_CACHE_MAX_SIZE=128  # 策略筛选缓存最大条目
# QUANTIA_FILTER_CACHE_TTL=600       # 筛选缓存 TTL（秒）

# ============ 日志 ============
# QUANTIA_LOG_MAX_BYTES=10485760     # 单个日志文件最大大小（字节，默认 10MB）
# QUANTIA_LOG_BACKUP_COUNT=5         # 日志轮转保留文件数

# ============ 交易 / 回测 ============
# QUANTIA_TURTLE_BALANCE=200000      # 海龟策略模拟资金
# QUANTIA_COMMISSION_RATE=0.00025    # 佣金率（单边，0.025%）
# QUANTIA_STAMP_TAX_RATE=0.0005     # 印花税（卖方，0.05%）
# QUANTIA_SLIPPAGE_RATE=0.0005      # 滑点率（单边，0.05%）

# ============ OOM 防护（低内存服务器） ============
# QUANTIA_STOP_SERVICES=nginx        # 内存密集型任务前停止的系统服务（空格分隔）
QUANTIA_NO_SERVICE_STOP=1            # 1=禁用自动停止/恢复服务；0=自动停止和恢复

# ============ Phase 8 鉴权 / RBAC ============
# 启用后校验 cookie/CSRF；未启用时所有 API 直通
# QUANTIA_AUTH_ENABLED=false         # 总开关；true/1/yes 启用
# QUANTIA_SESSION_TTL_HOURS=12       # 登录会话 TTL（小时，1-168）
# QUANTIA_SESSION_SECRET=            # Tornado secure_cookie 加密密钥（生产必填）

# ── 内嵌 admin 单账户（可选，DB 故障时仍可登录） ──
# QUANTIA_ADMIN_USER=admin
# QUANTIA_ADMIN_PASS_BCRYPT=         # bcrypt 哈希；为空则禁用 env 单账户
#   生成：python -c "import bcrypt; print(bcrypt.hashpw(b'your-pass', bcrypt.gensalt()).decode())"

# ── 钉钉 IM 回调 IP 白名单 ──
# QUANTIA_DINGTALK_CALLBACK_ALLOW_IPS=  # 逗号分隔，支持 IP 或 CIDR

# ============ 自助注册 / 邮箱验证码 ============
# QUANTIA_REGISTER_ENABLED=true      # 自助注册总开关
# QUANTIA_REGISTER_DEV_MODE=false    # 开发模式：响应回显验证码（生产务必关闭）
# QUANTIA_SMTP_HOST=smtp.exmail.qq.com
# QUANTIA_SMTP_PORT=465
# QUANTIA_SMTP_USER=noreply@yourdomain.com
# QUANTIA_SMTP_PASS=your_smtp_password
# QUANTIA_SMTP_FROM=noreply@yourdomain.com
# QUANTIA_SMTP_USE_SSL=true

# ============ IM 指令通道 ============
# QUANTIA_IM_COMMAND_ENABLED=false
# QUANTIA_IM_MAX_SINGLE_VALUE=100000     # 单笔指令最大金额（元）
# QUANTIA_IM_MAX_DAILY_VALUE=500000      # 单日累计金额上限（元）
# QUANTIA_IM_COMMAND_TTL_SECONDS=300     # 待确认指令的过期时间

# ============ Phase 7 实盘交易 / Phase 6 模拟盘 ============
# QUANTIA_LIVE_TRADING_ENABLED=false
# QUANTIA_LIVE_BROKER=dry_run
# QUANTIA_TRADING_HOURS=09:30-11:30,13:00-15:00
# QUANTIA_LIVE_EXECUTE_RPS=0
# QUANTIA_PAPER_DAILY_AFTER_HOUR=16

# ============ 验证中心 fallback 回测 ============
# QUANTIA_VERIFY_FALLBACK_ENABLED=true
# QUANTIA_VERIFY_FALLBACK_MAX_STOCKS=300
# QUANTIA_VERIFY_FALLBACK_WORKERS=4

# ============ 财务数据采集 ============
# QUANTIA_FINANCIAL_SLEEP=2.0        # 每只股票间隔（秒）
# QUANTIA_FINANCIAL_RETRIES=2        # 单只重试次数
# QUANTIA_FINANCIAL_RETRY_SLEEP=5    # 重试等待（秒）

# ============================================================
# 全量回测任务超时
# ============================================================
# QUANTIA_BACKTEST_TIMEOUT=7200          # analysis_daily_job 中回测子进程超时（秒）

# ============================================================
# 财报数据抓取（quantia/job/stock_financial_data.py）
# ============================================================
# QUANTIA_FINANCIAL_SLEEP=2.0            # 每只股票之间的间隔（秒）
# QUANTIA_FINANCIAL_RETRIES=2            # 单只重试次数
# QUANTIA_FINANCIAL_RETRY_SLEEP=5        # 重试间隔（秒）

# ============================================================
# 爬虫请求间隔（防限流；可全部关闭以加快本地调试）
# ============================================================
# QUANTIA_CRAWL_DELAY_ENABLED=true       # 0 = 完全关闭随机延迟
# QUANTIA_CRAWL_DELAY_EM_MIN=0.2         # 东方财富股票历史 K 线
# QUANTIA_CRAWL_DELAY_EM_MAX=0.5
# QUANTIA_CRAWL_DELAY_INDEX_MIN=0.2      # 东方财富指数 K 线
# QUANTIA_CRAWL_DELAY_INDEX_MAX=0.5
# QUANTIA_CRAWL_DELAY_TC_SHORT_MIN=0.3   # 腾讯短窗
# QUANTIA_CRAWL_DELAY_TC_SHORT_MAX=0.8
# QUANTIA_CRAWL_DELAY_TC_LONG_MIN=0.5    # 腾讯长窗
# QUANTIA_CRAWL_DELAY_TC_LONG_MAX=1.5
# QUANTIA_CRAWL_DELAY_SINA_MIN=3.0       # 新浪（最严，常 456）
# QUANTIA_CRAWL_DELAY_SINA_MAX=6.0

# ============================================================
# 内部 / 自动注入变量（不要手工写到 .env）
# ============================================================
# 以下变量由父进程在运行时设置，仅在子进程间传递阶段状态：
#   QUANTIA_PHASE2_FAILED   —— execute_daily_job 标记 Phase 2 失败，
#                              streaming_analysis_job 据此跳过分析阶段
